<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>MutagenManager</AssemblyName>
    <RootNamespace>MutagenManager</RootNamespace>
    <ApplicationIcon>Resources\mutagen.ico</ApplicationIcon>
    <AssemblyVersion>3.1.1.0</AssemblyVersion>
    <FileVersion>3.1.1.0</FileVersion>
    <Version>3.1.1</Version>
    <Company>fibanez7</Company>
    <Product>MutagenManager</Product>
    <Description>Mutagen sync manager with visual tray and settings panel</Description>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Resources\mutagen.ico" />
  </ItemGroup>

</Project>
