<Window x:Class="MutagenManager.Views.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log — Mutagen Manager"
        Width="820" Height="520"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- log content -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#F5F5F5"
                BorderBrush="#DDD" BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="↻ Actualizar" Padding="10,4"
                        Click="Refresh_Click" Margin="0,0,8,0"/>
                <CheckBox x:Name="AutoScrollCheck"
                          Content="Auto-scroll al final"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"/>
                <TextBlock x:Name="LineCountLabel"
                           VerticalAlignment="Center"
                           Foreground="#888" FontStyle="Italic" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- ── Log content (dark theme) ─────────────────────────────────────── -->
        <TextBox Grid.Row="1"
                 x:Name="LogContent"
                 IsReadOnly="True"
                 FontFamily="Consolas" FontSize="11"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 Padding="10,8"
                 BorderThickness="0"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 CaretBrush="#D4D4D4"
                 SelectionBrush="#264F78"/>

        <!-- ── Footer ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0"
                Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Abrir en Notepad" Padding="10,4"
                        Click="OpenNotepad_Click" Margin="0,0,8,0"/>
                <Button Content="Cerrar" Padding="16,4"
                        Click="Close_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
