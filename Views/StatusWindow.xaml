<Window x:Class="MutagenManager.Views.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Estado Global — Mutagen Manager"
        Width="760" Height="500"
        MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="*"/>      <!-- list -->
            <RowDefinition Height="4"/>      <!-- splitter -->
            <RowDefinition Height="110"/>    <!-- detail panel -->
            <RowDefinition Height="Auto"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="LastUpdatedLabel" VerticalAlignment="Center"
                       Foreground="#888" FontStyle="Italic" FontSize="11"/>
            <Button HorizontalAlignment="Right" Content="↻ Actualizar"
                    Click="Refresh_Click"/>
        </Grid>

        <!-- ── Status list ──────────────────────────────────────────────────── -->
        <ListView x:Name="StatusList" Grid.Row="1"
                  SelectionMode="Single"
                  SelectionChanged="StatusList_SelectionChanged"
                  VirtualizingPanel.IsVirtualizing="False">
            <ListView.View>
                <GridView>

                    <!-- Status dot -->
                    <GridViewColumn Header="" Width="26">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="10" Height="10"
                                         Fill="{Binding StatusBrush}"
                                         HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Nombre"      Width="150"
                                    DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Estado"      Width="110"
                                    DisplayMemberBinding="{Binding DisplayStatus}"/>
                    <GridViewColumn Header="Conflictos"  Width="90"
                                    DisplayMemberBinding="{Binding ConflictsText}"/>
                    <GridViewColumn Header="Problemas"   Width="90"
                                    DisplayMemberBinding="{Binding ProblemsText}"/>
                    <GridViewColumn Header="Ruta Local"  Width="230"
                                    DisplayMemberBinding="{Binding LocalPath}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Splitter ─────────────────────────────────────────────────────── -->
        <GridSplitter Grid.Row="2" Height="4"
                      HorizontalAlignment="Stretch"
                      Background="#DDD" Cursor="SizeNS"/>

        <!-- ── Detail panel ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="3" Margin="0,4,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="DetailText"
                           Margin="8,6" FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap" Foreground="#333"
                           LineHeight="16"/>
            </ScrollViewer>
        </Border>

        <!-- ── Footer ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="4" BorderBrush="#DDD" BorderThickness="0,1,0,0"
                Padding="0,8,0,0" Margin="0,8,0,0">
            <Grid>
                <Button x:Name="TerminateOrphansBtn" HorizontalAlignment="Left"
                        Content="Terminar huérfanas" Padding="12,4"
                        IsEnabled="False" Click="TerminateOrphans_Click"
                        ToolTip="Sesiones activas en mutagen que no están en config.json"/>
                <Button HorizontalAlignment="Right" Content="Cerrar"
                        Padding="16,4" Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
